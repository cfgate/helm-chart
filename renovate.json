{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "schedule": ["before 9am on monday"],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["templates/crds/*.yaml"],
      "matchStrings": [
        "default:\\s*ghcr\\.io/inherent-design/cloudflared:(?<currentValue>\\S+)"
      ],
      "depNameTemplate": "ghcr.io/inherent-design/cloudflared",
      "datasourceTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "description": "Cloudflared fork image tracks cfgate source; manual review only",
      "matchPackageNames": ["ghcr.io/inherent-design/cloudflared"],
      "enabled": false
    }
  ]
}
